{
  "name": "ide-ia-backend",
  "version": "1.0.0",
  "description": "Backend IDE-IA — Gestión de Agentes Inteligentes con Anthropic Claude",
  "author": "chicha",
  "private": true,
  "license": "LPG-Bolivia",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "nest start",
    "start:dev": "NODE_ENV=development nest start --watch",
    "start:prod": "NODE_ENV=production node dist/src/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migrations:run": "npm run typeorm -- migration:run -d ormconfig-default.ts",
    "migrations:revert": "npm run typeorm -- migration:revert -d ormconfig-default.ts",
    "prebuild": "rimraf dist"
  },
  "dependencies": {
    "@nestjs/common": "9.3.1",
    "@nestjs/config": "2.3.0",
    "@nestjs/core": "9.3.1",
    "@nestjs/jwt": "10.0.1",
    "@nestjs/passport": "9.0.1",
    "@nestjs/platform-express": "^9.4.3",
    "@nestjs/schedule": "^2.2.0",
    "@nestjs/swagger": "6.1.4",
    "@nestjs/throttler": "^4.0.0",
    "@nestjs/typeorm": "9.0.1",
    "@types/bcrypt": "5.0.0",
    "@types/pdfkit": "^0.17.6",
    "axios": "^1.13.6",
    "bcrypt": "5.1.0",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.0",
    "cls-rtracer": "2.6.2",
    "connect-typeorm": "2.0.0",
    "cookie-parser": "1.4.6",
    "dayjs": "1.11.7",
    "dotenv": "^16.0.3",
    "exceljs": "^4.4.0",
    "express-session": "1.17.3",
    "helmet": "6.0.1",
    "nanoid": "3.3.4",
    "nestjs-pino": "3.1.2",
    "passport": "0.6.0",
    "passport-jwt": "4.0.1",
    "passport-local": "1.0.0",
    "pdfkit": "^0.18.0",
    "pg": "8.9.0",
    "pino": "8.8.0",
    "pino-http": "8.3.2",
    "pino-pretty": "9.1.1",
    "reflect-metadata": "0.1.13",
    "rimraf": "4.1.2",
    "rxjs": "7.8.0",
    "swagger-ui-express": "4.6.0",
    "typeorm": "0.3.11",
    "uuid": "9.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "9.1.9",
    "@nestjs/schematics": "9.0.4",
    "@nestjs/testing": "9.3.1",
    "@types/cookie-parser": "1.4.3",
    "@types/express": "4.17.16",
    "@types/express-session": "1.17.5",
    "@types/multer": "^2.1.0",
    "@types/node": "18.11.18",
    "@types/passport-local": "1.0.35",
    "@types/uuid": "9.0.0",
    "@typescript-eslint/eslint-plugin": "5.50.0",
    "@typescript-eslint/parser": "5.50.0",
    "eslint": "8.33.0",
    "eslint-config-prettier": "8.6.0",
    "eslint-plugin-prettier": "4.2.1",
    "prettier": "2.8.3",
    "ts-node": "10.9.1",
    "tsconfig-paths": "4.1.2",
    "typescript": "4.9.5"
  },
  "engines": {
    "node": "^18",
    "npm": ">=8"
  }
}
