# ── Servidor ──────────────────────────────────────────────
PORT=3001
PATH_SUBDOMAIN=api
NODE_ENV=development

# ── Base de datos PostgreSQL ───────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=ide_ia_db
DB_SCHEMA=public
LOG_SQL=false

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=ide_ia_jwt_secret_change_in_production
JWT_EXPIRES_IN=8h

# ── Sesión ────────────────────────────────────────────────
SESSION_SECRET=ide_ia_session_secret_change_in_production

# ── Anthropic API ─────────────────────────────────────────
ANTHROPIC_DEFAULT_MODEL=claude-haiku-4-5
